                <!-- Телефон -->
                <div class="phone-block">
                    <span class="phone-label">Телефон:</span>
                    <a href="tel:+79166978190" class="phone-number">+7 (916) 697-81-90</a>
                </div>

                <!-- Кнопка записи -->
                <button class="btn-enroll-header" @onclick="OpenModal">Записаться на занятие</button>
            </div>
        </div>
    </header>

    <!-- Навигационное меню -->
    <nav class="main-navigation">
        <div class="nav-container">
            <a href="/" class="nav-item @(IsActive("") ? "active" : "")">На главную</a>
            <a href="/#advantages" class="nav-item @(IsActive("advantages") ? "active" : "")">Почему мы</a>
            <a href="/#courses-list" class="nav-item @(IsActive("courses") ? "active" : "")">Программа</a>
            <a href="/children" class="nav-item @(IsActive("children") ? "active" : "")">Наши ученики</a>
            <a href="/enrollment" class="nav-item @(IsActive("enrollment") ? "active" : "")">Контакты</a>
        </div>
    </nav>

    <!-- Основной контент -->
    <main class="main-content">
        @Body
    </main>

    <!-- Подвал -->
    <footer class="site-footer">
        <div class="footer-container">
            <div class="footer-section">
                <h4>Дошкольный центр</h4>
                <p>Подготовка детей к школе<br>с любовью и заботой</p>
            </div>
            <div class="footer-section">
                <h4>Контакты</h4>
                <p>📍 г. Электросталь, ул. Ялагина, д. 10</p>
                <p>📞 +7 (909) 567-81-90</p>
                <p>✉️ info@vzglyad-budushchee.ru</p>
            </div>
            <div class="footer-section">
                <h4>Время работы</h4>
                <p>Пн-Пт: 8:00 - 19:00</p>
                <p>Сб: 9:00 - 15:00</p>
                <p>Вс: выходной</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Дошкольный центр "Взгляд в будущее". Все права защищены.</p>
        </div>
    </footer>

    <!-- МОДАЛЬНОЕ ОКНО -->
    <EnrollmentModal IsVisible="showModal" OnClose="CloseModal" OnSubmit="HandleEnrollment" />
</div>

@code {
    [Inject] private NavigationManager? Nav { get; set; }
    private bool showModal = false;

    private bool IsActive(string page)
    {
        if (string.IsNullOrEmpty(page))
            return Nav?.Uri == Nav?.BaseUri;
        return Nav?.Uri.Contains(page, StringComparison.OrdinalIgnoreCase) ?? false;
    }

    private void OpenModal()
    {
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task HandleEnrollment((string Name, string Phone) data)
    {
        // Здесь можно сохранить данные в базу
        Console.WriteLine($"Заявка: {data.Name}, {data.Phone}");
        await Task.CompletedTask;
    }
}